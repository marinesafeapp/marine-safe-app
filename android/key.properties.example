# Copy this file to key.properties and fill in your release keystore details.
# key.properties is gitignored; never commit real passwords.
#
# storeFile=../path/to/your/release.keystore
# storePassword=your_keystore_password
# keyPassword=your_key_password
# keyAlias=your_key_alias

storeFile=
storePassword=
keyPassword=
keyAlias=
