# Copy this file to key.properties and fill in your release keystore details.
# key.properties is git-ignored; do not commit real passwords.
# Use the SAME keystore you used when you first published this app to Play Store.
# Expected certificate SHA1 (from Play Console): 9A:E2:C4:1A:EA:1F:4E:FF:32:FC:61:7A:C6:67:11:75:9B:09:CD:F6

storePassword=your_keystore_password
keyPassword=your_key_password
keyAlias=your_key_alias
storeFile=../upload-keystore.jks
